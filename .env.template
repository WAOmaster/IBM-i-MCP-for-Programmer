# PUB400 IBM i MCP — Environment Configuration
# Copy this to .env and fill in your credentials

# Active environment (dev | test)
IBMI_ENV=dev

# Connection (filled automatically by configure_connection tool)
IBMI_HOST=PUB400.COM
IBMI_PORT=2222
IBMI_USER=SHOLON
IBMI_PASSWORD=

# Library list (comma-separated, prepended to every CL command)
IBMI_LIBRARY_LIST=

# Timeouts
IBMI_TIMEOUT_SEC=90
IBMI_SQL_TIMEOUT_SEC=120

# SSH pool size
IBMI_POOL_MAX=5
IBMI_POOL_IDLE_SEC=120
